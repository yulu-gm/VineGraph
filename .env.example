# Required controller API key for DeepSeek-backed controller nodes.
DEEPSEEK_API_KEY=

# Default Codex model used by execute nodes in the project task loop.
AGENTGRAPH_CODEX_MODEL=gpt-5.5

# Default Codex reasoning effort for implementation and review agents.
AGENTGRAPH_CODEX_REASONING_EFFORT=high

# Agent CLI discovery runs once when the desktop/server app starts.
# Leave these blank for auto-detection. AgentGraph skips node_modules/.bin shadows
# and writes the resolved executable path into the running process environment.
#
# macOS Homebrew examples:
# AGENTGRAPH_CODEX_PATH=/opt/homebrew/bin/codex
# AGENTGRAPH_CLAUDE_PATH=/opt/homebrew/bin/claude
#
# Windows npm global examples:
# AGENTGRAPH_CODEX_PATH=%APPDATA%\npm\codex.cmd
# AGENTGRAPH_CLAUDE_PATH=%APPDATA%\npm\claude.cmd
AGENTGRAPH_CODEX_PATH=
AGENTGRAPH_CLAUDE_PATH=

# CLI invocation style used by execute backends:
# Codex receives the rendered prompt on stdin:
#   <AGENTGRAPH_CODEX_PATH|codex> exec [--model <model>] [--config model_reasoning_effort="<effort>"] [--sandbox <mode>] --ephemeral --skip-git-repo-check -
# Claude receives the rendered prompt through -p:
#   <AGENTGRAPH_CLAUDE_PATH|claude> -p "<prompt>" --output-format text --no-session-persistence --permission-mode bypassPermissions --max-budget-usd 10
